    <script>
        // Navbar Scroll Background Change
        window.addEventListener('scroll', () => {
            const nav = document.getElementById('navbar');
            if (window.scrollY > 50) {
                nav.classList.add('nav-scrolled');
            } else {
                nav.classList.remove('nav-scrolled');
            }
        });

        // Form Submission Animation (Luxury UX)
        document.getElementById('admissionForm').addEventListener('submit', function(e) {
            e.preventDefault();
            
            const btn = document.getElementById('submitBtn');
            const originalText = btn.innerHTML;
            
            btn.innerHTML = '<i class="fas fa-circle-notch fa-spin"></i> Processing...';
            btn.style.pointerEvents = 'none';
            
            setTimeout(() => {
                btn.innerHTML = '<i class="fas fa-check-circle"></i> Query Sent Securely';
                btn.style.background = 'var(--neon-gold)';
                btn.style.color = '#000';
                btn.style.boxShadow = '0 0 30px var(--gold-glow)';
                
                e.target.reset();
                
                setTimeout(() => {
                    btn.innerHTML = originalText;
                    btn.style.background = 'linear-gradient(90deg, #d4af37, var(--neon-gold))';
                    btn.style.color = '#000';
                    btn.style.boxShadow = 'none';
                    btn.style.pointerEvents = 'auto';
                }, 3000);
            }, 1500);
        });
    </script>
</body>
</html>
