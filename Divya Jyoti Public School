    <style>
        /* =========================================
           1. CORE VARIABLES & SETUP
           ========================================= */
        :root {
            --bg-dark: #020203;
            --neon-cyan: #00f3ff;
            --neon-gold: #FFD700; 
            --gold-glow: rgba(255, 215, 0, 0.4);
            --text-main: #ffffff;
            --text-muted: #8892b0;
            --glass-bg: rgba(10, 12, 18, 0.6);
            --glass-border: rgba(255, 215, 0, 0.15); 
            --transition: all 0.4s cubic-bezier(0.25, 1, 0.5, 1);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        html { scroll-behavior: smooth; font-family: 'Inter', 'Segoe UI', sans-serif; }
        body { background-color: var(--bg-dark); color: var(--text-main); overflow-x: hidden; }

        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: var(--bg-dark); }
        ::-webkit-scrollbar-thumb { background: var(--neon-gold); border-radius: 10px; }

        /* =========================================
           2. AURORA + GOLDEN SVG GRID BACKGROUND
           ========================================= */
        .vfx-bg { 
            position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; 
            z-index: -10; overflow: hidden; background: radial-gradient(circle at center, #050508 0%, #000000 100%); 
            perspective: 1000px; pointer-events: none;
        }

        /* Moving Orbs */
        .orb { position: absolute; border-radius: 50%; filter: blur(80px); opacity: 0.4; animation: floatOrb 15s infinite alternate ease-in-out; }
        .orb-1 { top: -10%; left: -10%; width: 50vw; height: 50vw; background: rgba(0, 243, 255, 0.15); animation-delay: 0s; }
        .orb-2 { bottom: -10%; right: -10%; width: 60vw; height: 60vw; background: rgba(255, 215, 0, 0.1); animation-delay: -5s; }

        @keyframes floatOrb {
            0% { transform: translate(0, 0) scale(1); }
            50% { transform: translate(5%, 10%) scale(1.2); }
            100% { transform: translate(-5%, -5%) scale(0.9); }
        }

        /* SVG Grid */
        .svg-grid { 
            position: absolute; width: 200%; height: 200%; top: -50%; left: -50%; 
            transform: rotateX(65deg) translateY(-100px) translateZ(-200px); opacity: 0.8; 
        }
        .grid-line { stroke: rgba(255, 255, 255, 0.03); stroke-width: 1.5; fill: none; }
        .grid-laser-gold {
            stroke: var(--neon-gold); stroke-width: 2.5; fill: none;
            filter: drop-shadow(0 0 12px var(--neon-gold));
            stroke-dasharray: 200 3000; animation: laserRun 10s linear infinite;
        }
        .grid-laser-gold.reverse { stroke-dasharray: 300 4000; animation: laserRunRev 15s linear infinite; }

        @keyframes laserRun { from { stroke-dashoffset: 3200; } to { stroke-dashoffset: 0; } }
        @keyframes laserRunRev { from { stroke-dashoffset: -4300; } to { stroke-dashoffset: 0; } }

        /* =========================================
           3. PREMIUM NAVBAR
           ========================================= */
        nav { 
            position: fixed; top: 0; width: 100%; display: flex; justify-content: space-between; align-items: center;
            padding: 20px 50px; background: rgba(2, 2, 3, 0.75); backdrop-filter: blur(25px); -webkit-backdrop-filter: blur(25px);
            border-bottom: 1px solid var(--glass-border); z-index: 1000; transition: var(--transition);
        }

        .nav-scrolled { box-shadow: 0 10px 30px rgba(0,0,0,0.9); padding: 15px 50px; background: rgba(2, 2, 3, 0.95); }
        .logo { font-size: 1.5rem; font-weight: 900; letter-spacing: 1px; color: #fff; text-shadow: 0 0 15px var(--gold-glow); }
        .logo span { display: block; font-size: 0.6rem; letter-spacing: 4px; color: var(--neon-gold); text-transform: uppercase; }
        
        .nav-links { display: flex; gap: 30px; align-items: center; }
        .nav-links a { color: var(--text-main); text-decoration: none; font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1.5px; transition: var(--transition); cursor: pointer; }
        .nav-links a:hover { color: var(--neon-gold); text-shadow: 0 0 10px var(--neon-gold); }

        .nav-btn {
            padding: 12px 28px; border: 1px solid var(--neon-gold); border-radius: 50px;
            background: rgba(255, 215, 0, 0.05); color: var(--neon-gold); font-size: 0.8rem; font-weight: bold; text-transform: uppercase;
            cursor: pointer; transition: var(--transition); letter-spacing: 1px;
        }

        .nav-btn:hover { background: var(--neon-gold); color: #000; box-shadow: 0 0 20px var(--gold-glow); }

        @media (max-width: 900px) { nav { padding: 15px; flex-direction: column; gap: 15px; } .nav-links { display: flex; flex-wrap: wrap; justify-content: center; gap: 15px; } }

        /* =========================================
           4. HERO SECTION
           ========================================= */
        .hero { height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 0 20px; }
        .hero h1 { font-size: clamp(3rem, 6vw, 5.5rem); font-weight: 900; line-height: 1.1; margin-bottom: 20px; text-shadow: 0 10px 30px rgba(0,0,0,0.8); }
        .hero h1 span { color: var(--neon-gold); text-shadow: 0 0 20px var(--gold-glow); }
        .hero p { color: var(--text-muted); font-size: clamp(0.9rem, 2vw, 1.1rem); max-width: 700px; line-height: 1.6; }

        /* =========================================
           5. MAIN SECTIONS & GLASS PANELS
           ========================================= */
        section { padding: 80px 5%; max-width: 1300px; margin: 0 auto; position: relative; z-index: 10; }
        .section-title { font-size: clamp(2rem, 3.5vw, 2.5rem); font-weight: 800; margin-bottom: 40px; color: #fff; position: relative; display: inline-block; }
        .section-title::after { content: ''; position: absolute; left: 0; bottom: -10px; width: 50px; height: 3px; background: var(--neon-gold); box-shadow: 0 0 10px var(--neon-gold); }
        
        .glass-panel {
            background: var(--glass-bg); backdrop-filter: blur(20px); border: 1px solid var(--glass-border);
            border-radius: 20px; padding: clamp(30px, 5vw, 50px); box-shadow: 0 20px 40px rgba(0,0,0,0.8); margin-bottom: 30px;
        }
        .glass-panel h3 { font-size: 1.4rem; color: #fff; margin-bottom: 15px; margin-top: 30px; }
        .glass-panel h3:first-child { margin-top: 0; }
        .glass-panel p { color: var(--text-muted); line-height: 1.8; margin-bottom: 15px; }
        .glass-panel ul { list-style: none; margin-top: 20px; }
        .glass-panel ul li { color: var(--text-muted); padding: 12px 0; border-bottom: 1px solid rgba(255,255,255,0.05); }
        .glass-panel ul li::before { content: '▹'; color: var(--neon-gold); font-weight:bold; margin-right: 15px; }

        /* =========================================
           6. CAMPUS EXPERIENCE CARDS
           ========================================= */
        .campus-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 30px; }
        .campus-card { background: #000; border: 1px solid var(--glass-border); border-radius: 16px; overflow: hidden; height: 280px; position: relative; transition: var(--transition); cursor: pointer; }
        .campus-card img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s ease; opacity: 0.8; }
        .campus-card::before { content: ''; position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.95) 0%, transparent 80%); z-index: 1; }
        .card-info { position: absolute; bottom: 0; left: 0; width: 100%; padding: 25px; z-index: 2; }
        .card-info h4 { font-size: 1.3rem; color: #fff; margin-bottom: 5px; }
        .card-info p { font-size: 0.85rem; color: var(--neon-gold); margin: 0; }
        .campus-card:hover img { transform: scale(1.1); opacity: 1; filter: brightness(1.1); }
        .campus-card:hover { border-color: var(--neon-gold); box-shadow: 0 10px 30px var(--gold-glow); transform: translateY(-5px); }

        /* =========================================
           7. GALLERY GRID (ON MAIN PAGE)
           ========================================= */
        .masonry-gallery { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; }
        .masonry-gallery img {
            width: 100%; height: 240px; object-fit: cover; border-radius: 12px;
            border: 1px solid rgba(255,215,0,0.1); transition: all 0.5s ease; cursor: pointer;
        }
        .masonry-gallery img:hover { transform: scale(1.05); border-color: var(--neon-gold); box-shadow: 0 15px 30px var(--gold-glow); z-index: 2; position: relative; }

        /* =========================================
           8. ADMISSION ENQUIRY FORM (ON MAIN PAGE)
           ========================================= */
